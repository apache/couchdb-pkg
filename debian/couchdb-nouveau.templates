# NOTE TO DEVELOPERS
# If you change this file, run debconf-updatepo !
# Failure to do so will result in a rejected pull request.

Template: couchdb-nouveau/postrm_remove_indexes
Type: boolean
Default: false
_Description: Remove all CouchDB Nouveau index data?
 The /var/lib/nouveau/ directory containing all CouchDB Nouveau index data will be
 removed. This will also remove the nouveau user and group.
